# Required workspace configuration
export CICIEC_WORKSPACE=/path/to/ciciec_workspace
export CICIEC_SUBMISSION_REPO=/path/to/submission-repository
export CICIEC_SUBMISSION_REF=submit/codex
export CICIEC_CI_REF="$CICIEC_SUBMISSION_REF"

# GitLab API configuration
export CICIEC_GITLAB_API_URL=https://gitlab.example.com/api/v4
export CICIEC_GITLAB_PROJECT_ID=123
export GITLAB_TOKEN='replace-in-current-shell'

# Online judge configuration
export CICIEC_JUDGE_BASE_URL=https://judge.example.com
export CICIEC_STAGE3_LAB_ID='optional-if-auto-discovery-works'
export CICIEC_JUDGE_USER='replace-in-current-shell'
export CICIEC_JUDGE_PASSWORD='replace-in-current-shell'

# Optional polling configuration
export CICIEC_CI_LIMIT=30
export CICIEC_CI_POLL_SECONDS=30
export CICIEC_CI_TIMEOUT_SECONDS=3600
